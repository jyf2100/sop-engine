# SOP Engine - 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sop_engine

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# OpenClaw 配置
# ============================================
# OpenClaw 服务地址
OPENCLAW_URL=http://localhost:18789

# OpenClaw Webhook Token（必需，从 OpenClaw 获取）
OPENCLAW_TOKEN=your-openclaw-token-here

# OpenClaw 请求超时（秒）
OPENCLAW_TIMEOUT=30

# OpenClaw workspace 根目录
OPENCLAW_WORKSPACE_ROOT=~/.openclaw

# ============================================
# 凭证加密配置
# ============================================
# 用于加密存储 OpenClaw 凭证的密钥（必需，32 字节 base64）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
CREDENTIAL_ENCRYPTION_KEY=your-32-byte-base64-key-here

# ============================================
# 应用配置
# ============================================
# 运行环境: development, staging, production
ENVIRONMENT=development

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# API 服务端口
PORT=8000
